# Reuse values from producer/.env where possible
BOOTSTRAP_SERVERS=pkc-xxxx.us-west-2.aws.confluent.cloud:9092
KAFKA_API_KEY=...
KAFKA_API_SECRET=...
SCHEMA_REGISTRY_URL=https://psrc-xxxxx.us-west-2.aws.confluent.cloud
SR_API_KEY=...
SR_API_SECRET=...

# Agent inputs/outputs
CLEANED_TOPIC=heart-rate-cleaned
SUMMARY_TOPIC=patient.heart_state.snapshot
WINDOW_SECONDS=30
POLL_MILLIS=1000

# Optional OpenAI settings (fallback to rule-based summary if unset)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
