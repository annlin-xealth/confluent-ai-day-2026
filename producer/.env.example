# Copy this file to .env and fill values.
# cp .env.example .env

# Confluent Kafka cluster endpoint (no protocol prefix)
BOOTSTRAP_SERVERS=pkc-xxxxx.us-west-2.aws.confluent.cloud:9092

# Confluent Schema Registry endpoint
SCHEMA_REGISTRY_URL=https://psrc-xxxxx.us-west-2.aws.confluent.cloud

# Kafka API credentials (cluster-scoped)
KAFKA_API_KEY=
KAFKA_API_SECRET=

# Schema Registry API credentials
SR_API_KEY=
SR_API_SECRET=

# Topic + simulation settings
RAW_TOPIC=heart-rate-raw
TOPICS=heart-rate-raw,heart-rate-cleaned,heart-rate-features,heart-rate-risk-events,patient.heart_state.snapshot
TOPIC_PARTITIONS=6
TOPIC_REPLICATION_FACTOR=3
EVENTS_PER_SECOND=1
TOTAL_EVENTS=0
HEART_RATE_MODE=normal
PATIENT_ID=user-00987
DEVICE_ID=dev-watch-4421
SOURCE_APP_ID=wearable-ingest-service
SCHEMA_PATH=../schemas/HeartRate.avsc

# Optional client/security tuning
SECURITY_PROTOCOL=SASL_SSL
SASL_MECHANISM=PLAIN
SR_BASIC_AUTH_CREDENTIALS_SOURCE=USER_INFO
AUTO_REGISTER_SCHEMAS=true
